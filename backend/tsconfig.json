{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,

		/* Path Mapping */
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@controllers/*": ["./src/controllers/*"],
			"@routes/*": ["./src/routes/*"],
			"@models/*": ["./src/models/*"],
			"@services/*": ["./src/services/*"],
			"@middlewares/*": ["./src/middlewares/*"],
			"@utils/*": ["./src/utils/*"],
			"@config/*": ["./src/config/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
