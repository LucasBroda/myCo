# Configuration de la base de données PostgreSQL
# Remplacez 'user' et 'password' par vos identifiants PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/myco

# URL Redis (optionnel, pour le cache)
REDIS_URL=redis://localhost:6379

# Secrets JWT - NE PAS utiliser ces valeurs par défaut en production
# Générez de nouveaux secrets avec : openssl rand -base64 64
ACCESS_TOKEN_SECRET=changeme_access_secret_minimum_32_chars_long
REFRESH_TOKEN_SECRET=changeme_refresh_secret_minimum_32_chars_long

# Clé API Pokemon TCG (optionnelle)
# Obtenez une clé sur : https://pokemontcg.io
POKEMON_TCG_API_KEY=

# Tokens API tierces (optionnels)
CARDMARKET_APP_TOKEN=

# eBay API credentials (optionnel)
# Obtenez vos credentials sur : https://developer.ebay.com
# 1. Créez un compte développeur
# 2. Créez une application (Production ou Sandbox)
# 3. Copiez le Client ID et Client Secret
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_US  # Options: EBAY_US, EBAY_FR, EBAY_GB, etc.

# Configuration du serveur
PORT=5000
NODE_ENV=development
